# ============================================================
# revenue-recovery-kit — backend environment variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/revenue_recovery

# --- Supabase (Auth + DB) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# JWT verification — ES256 asymmetric keys (current Supabase default)
# Find this at: Settings → API → JWT Settings → JWKS URL
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# Legacy HS256 secret — kept for reference but no longer used by the backend.
# Remove once all projects have migrated to asymmetric keys.
SUPABASE_JWT_SECRET=

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- GHL (Go High Level) ---
GHL_WEBHOOK_SECRET=
GHL_API_KEY=

# --- Messaging (optional) ---
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- App ---
FRONTEND_ORIGIN=http://localhost:3000
